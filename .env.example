# Naver News Search API
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# MySQL / MariaDB
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=election_news
DB_USER=election_user
DB_PASSWORD=change-me
DB_CHARSET=utf8mb4

# Ingestion behavior
SEARCH_KEYWORDS=지방선거
NAVER_DISPLAY=100
NAVER_MAX_PAGES=1
INGESTION_INTERVAL_SECONDS=3600

# Optional article enrichment
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REQUEST_TIMEOUT_SECONDS=30
ARTICLE_FETCH_TIMEOUT_SECONDS=10
ENRICHMENT_MAX_ARTICLE_CHARS=12000
